  /* Hero'da 50/50 grid aktif olur */
}

/* Masaüstü */
@media (min-width: 1024px) {
  /* Tam navigasyon görünür */
}

/* Geniş ekran */
@media (min-width: 1280px) {
  /* İçerik max-width sınırına ulaşır */
}

/* Mobil (max-width ile) */
@media (max-width: 767px) {
  .hero {
    grid-template-columns: 1fr;   /* Tek sütuna geç */
